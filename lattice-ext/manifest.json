{
  "manifest_version": 2,
  "name": "Lattice",
  "version": "0.1.4",
  "description": "Access .loom sites over local HTTPS on the Lattice network",
  "permissions": [
    "proxy",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "tabs"
  ],
  "background": {
    "scripts": ["config.js", "background.js"]
  },
  "browser_action": {},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://lattice.benjf.dev/*",
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": ["site-detect.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["setup.html", "setup.js", "config.js"],
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lattice@fordz0",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
