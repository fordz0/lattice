{
  "manifest_version": 2,
  "name": "Lattice",
  "version": "0.1.0",
  "description": "Access .loom sites over local HTTPS on the Lattice network",
  "permissions": [
    "proxy",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {},
  "content_scripts": [
    {
      "matches": ["http://*.loom/*", "https://*.loom/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://lattice.benjf.dev/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*"
      ],
      "js": ["site-detect.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": ["setup.html", "setup.js"],
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lattice@fordz0",
      "strict_min_version": "91.1.0"
    }
  }
}
